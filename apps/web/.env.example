# Sao chép file này thành `.env` và điền giá trị thật.
# KHÔNG commit file `.env` (đã được .gitignore bỏ qua).

# URL API backend (Fastify). Để trống thì api.js dùng '/api'.
VITE_API_URL=http://localhost:3000/api

# URL WebSocket realtime để nghe trạng thái giao dịch.
VITE_WS_URL=ws://localhost:3001
