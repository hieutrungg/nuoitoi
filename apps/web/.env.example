# Sao chép thành `.env` và điền giá trị. File `.env` đã được .gitignore bỏ qua.

# ---- Công khai (in trên QR, KHÔNG phải bí mật) ----
VITE_API_URL=/api
VITE_BANK_BIN=970422            # Mã BIN ngân hàng (MB Bank = 970422)
VITE_ACCOUNT_NUMBER=0000000000  # Số tài khoản nhận tiền
VITE_ACCOUNT_NAME=NGUYEN VAN A  # Tên chủ tài khoản (không dấu)

# ---- BÍ MẬT — chỉ đặt ở serverless (Vercel env), KHÔNG commit ----
# SEPAY_TOKEN=...                # API token của SePay
# SEPAY_ACCOUNT_NUMBER=0000000000
